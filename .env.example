# Bungie API — https://www.bungie.net/en/Application 에서 발급
BUNGIE_API_KEY=

# Bungie OAuth (창고 가져오기/정리 기능에서 사용)
BUNGIE_OAUTH_CLIENT_ID=
# Confidential 앱이면 secret 입력. 비우면 Public 클라이언트(리프레시 토큰 없음).
BUNGIE_OAUTH_CLIENT_SECRET=
BUNGIE_OAUTH_AUTHORIZE_URL=https://www.bungie.net/en/OAuth/Authorize
# bungie.net 앱에 등록한 redirect URL 과 정확히 일치해야 함.
BUNGIE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/bungie/callback
# OAuth 콜백 성공 후 돌아갈 프론트엔드 주소
FRONTEND_URL=http://localhost:8080

# 적재할 매니페스트 로케일 (한국어 우선)
MANIFEST_LOCALE=ko
MANIFEST_LOCALE_FALLBACK=en

# SQLite 경로 (Docker 에서는 /app/data/app.sqlite 기본)
# DB_PATH=

# voltron 커뮤니티 집계 위시리스트 (메타/인기도 부트스트랩 소스)
VOLTRON_URL=https://raw.githubusercontent.com/48klocs/dim-wish-list-sources/master/voltron.txt
