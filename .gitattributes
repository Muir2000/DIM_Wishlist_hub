# Normalize text files for consistent GitHub diffs.
* text=auto eol=lf

# Windows script files may keep CRLF locally.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary/generated artifacts.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.sqlite binary
*.db binary
*.zip binary
*.7z binary
*.tar binary
*.gz binary